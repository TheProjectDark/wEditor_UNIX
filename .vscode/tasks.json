{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-wx",
            "type": "shell",
            "command": "make",
            "args": ["clean", "build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "run-wx",
            "type": "shell",
            "command": "./wEditor",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": ["build-wx"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        }
    ]
}
